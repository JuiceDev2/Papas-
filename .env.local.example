# Copia este archivo a ".env.local" y llena los valores desde
# Supabase > Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Solo se usa en el servidor (Server Actions). NUNCA exponer al cliente.
# Se usa para invitar/crear cuentas de personal (Propietario/Admin/Colaborador).
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
